          </div>
        </div>
      </div>
    </section>

    <section id="reading" class="lp-section">
      <div class="lp-wrap">
        <div class="lp-section-head lp-reveal">
          <div class="lp-ornament" aria-hidden="true">
            <span class="lp-rule"></span>
            <span set:html={cross()} />
            <span class="lp-rule"></span>
          </div>
          <h2 class="lp-section-title">Currently reading</h2>
          <p class="lp-sub">Side reading, running parallel to the work.</p>
        </div>

        <div class="lp-reading lp-reveal">
          {reading.map((book) => (
            <article class="lp-book">
              <h3 class="lp-book-title">{book.title}</h3>
              {book.subtitle && <p class="lp-book-subtitle">{book.subtitle}</p>}
              <p class="lp-book-author">{book.author}</p>
              {book.quote && (
                <blockquote class="lp-book-quote">
                  <p>&ldquo;{book.quote}&rdquo;</p>
                </blockquote>
              )}
            </article>
          ))}
        </div>
      </div>
    </section>

    <section id="contact" class="lp-contact lp-section">
      <div class="lp-wrap">
        <div class="lp-section-head lp-reveal">
          <div class="lp-ornament" aria-hidden="true">
            <span class="lp-rule"></span>
            <span set:html={cross()} />
            <span class="lp-rule"></span>
          </div>
        </div>
        <h2 class="lp-contact-title lp-reveal">Let&rsquo;s <span>talk.</span></h2>
        <blockquote class="lp-contact-pull lp-reveal">
          <p>{contact.pull}</p>
          <cite>{contact.pullAttr}</cite>
        </blockquote>
        <div class="lp-contact-grid lp-reveal">
          <div class="lp-contact-cell">
            <div class="lp-contact-label">Email</div>
            <div class="lp-contact-value"><a href={`mailto:${site.email}`}>{emailDisplay}</a></div>
          </div>
          <div class="lp-contact-cell">
            <div class="lp-contact-label">Currently</div>
            <div class="lp-contact-value">{contact.currently}</div>
          </div>
          <div class="lp-contact-cell">
            <div class="lp-contact-label">Languages</div>
            <div class="lp-contact-value">English · Swahili · French · Luganda</div>
          </div>
        </div>
        <div class="lp-contact-social lp-reveal">
          <a href={site.social.github} target="_blank" rel="noopener noreferrer">GitHub</a>
          <a href={site.social.linkedin} target="_blank" rel="noopener noreferrer">LinkedIn</a>
          <a href={site.social.x} target="_blank" rel="noopener noreferrer">X</a>
        </div>
      </div>
    </section>

    <section class="lp-closing">
      <div class="lp-wrap">
        <div class="lp-ornament lp-reveal" aria-hidden="true">
          <span class="lp-rule"></span>
          <span set:html={cross(28)} />
          <span class="lp-rule"></span>
        </div>
        <h2 class="lp-closing-quote lp-reveal">Gakyali Mabaga.</h2>
        <p class="lp-closing-attr lp-reveal">Luganda — so little done, so much more to do.</p>
      </div>
    </section>
  </main>

  <footer class="lp-footer">
    <div class="lp-wrap">
      <div class="lp-ornament" aria-hidden="true">
        <span class="lp-rule"></span>
        <span set:html={cross(18)} />
        <span class="lp-rule"></span>
      </div>
      <div>Mbasha Seth · Uganda · MMXXVI</div>
    </div>
  </footer>
</div>

<script>
  (() => {
    document.documentElement.classList.add("lp-js-ready");

    const nav = document.querySelector(".lp-nav");
    const updateNav = () => nav?.classList.toggle("is-scrolled", window.scrollY > 8);
    updateNav();
    window.addEventListener("scroll", updateNav, { passive: true });

    const revealAll = () => {
      document.querySelectorAll(".lp-reveal").forEach((el) => el.classList.add("is-in"));
    };

    if ("IntersectionObserver" in window) {
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) entry.target.classList.add("is-in");
          });
        },
        { threshold: 0.05 }
      );

      document.querySelectorAll(".lp-reveal").forEach((el) => observer.observe(el));
      setTimeout(revealAll, 800);
    } else {
      revealAll();
    }

    const details = Array.from(document.querySelectorAll(".lp-work-details"));
    details.forEach((detail) => {
      detail.addEventListener("toggle", () => {
        if (detail.open) {
          details.forEach((other) => {
            if (other !== detail) other.removeAttribute("open");
          });
        }
      });
    });
  })();
</script>

<style is:global>
  .lp-page {
    --lp-paper: #faf8f3;
    --lp-paper-2: #f2eee3;
    --lp-ink: #2c2420;
    --lp-ink-2: #5a4f47;
    --lp-ink-3: #8b7e72;
    --lp-rule: #e5ddc9;
    --lp-gold: #b59b6e;
    --lp-gold-2: #9c8358;
    --lp-sapphire: #1b365d;
    --lp-display: "Cinzel", "Trajan Pro", "Cormorant Garamond", Georgia, serif;
    --lp-serif: "Cormorant Garamond", "EB Garamond", Georgia, serif;
    --lp-sans: "Inter", "Helvetica Neue", Helvetica, Arial, sans-serif;
    --lp-mono: "JetBrains Mono", ui-monospace, "SF Mono", Menlo, monospace;
    --lp-maxw: 1080px;
    --lp-pad: clamp(24px, 5vw, 72px);
    --lp-fast: 220ms cubic-bezier(0.2, 0.7, 0.2, 1);
    --lp-base: 420ms cubic-bezier(0.2, 0.7, 0.2, 1);
    --lp-slow: 720ms cubic-bezier(0.2, 0.7, 0.2, 1);

    min-height: 100vh;
    background: var(--lp-paper);
    color: var(--lp-ink);
    font-family: var(--lp-serif);
    font-size: 19px;
    line-height: 1.6;
    text-rendering: optimizeLegibility;
    -webkit-font-smoothing: antialiased;
  }

  .lp-page * {
    box-sizing: border-box;
  }

  .lp-page a {
    color: inherit;
    text-decoration: none;
  }

  .lp-page :where(h1, h2, h3, h4, p, blockquote, figure) {
    margin: 0;
  }

  .lp-page ::selection {
    background: var(--lp-sapphire);
    color: var(--lp-paper);
  }

  .lp-wrap {
    max-width: var(--lp-maxw);
    margin: 0 auto;
    padding-left: var(--lp-pad);
    padding-right: var(--lp-pad);
  }

  .lp-nav {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in oklab, var(--lp-paper) 90%, transparent);
    border-bottom: 1px solid transparent;
    backdrop-filter: saturate(140%) blur(10px);
    -webkit-backdrop-filter: saturate(140%) blur(10px);
    transition: border-color var(--lp-base);
  }

  .lp-nav.is-scrolled {
    border-bottom-color: var(--lp-rule);
  }

  .lp-nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 72px;
  }

  .lp-brand,
  .lp-nav-links,
  .lp-work-year,
  .lp-work-category,
  .lp-case-block h3,
  .lp-case-links a,
  .lp-other-work summary,
  .lp-other-year,
  .lp-other-link,
  .lp-rec-issuer,
  .lp-contact-label,
  .lp-contact-social,
  .lp-footer {
    font-family: var(--lp-display);
    text-transform: uppercase;
  }

  .lp-brand {
    display: flex;
    align-items: center;
    gap: 12px;
    color: var(--lp-ink);
    font-size: 13px;
    letter-spacing: 0.32em;
  }

  .lp-brand svg {
    color: var(--lp-gold);
    display: block;
  }

  .lp-nav-links {
    display: flex;
    align-items: center;
    gap: 30px;
  }

  .lp-nav-links a {
    position: relative;
    padding: 6px 0;
    color: var(--lp-ink-2);
    font-size: 11px;
    letter-spacing: 0.28em;
    transition: color var(--lp-fast);
  }

  .lp-nav-links a::after,
  .lp-contact-social a::after,
  .lp-rec-more a::after {
    content: "";
    position: absolute;
    left: 50%;
    right: 50%;
    bottom: 0;
    height: 1px;
    background: var(--lp-gold);
    transition: left var(--lp-base), right var(--lp-base);
  }

  .lp-nav-links a:hover,
  .lp-contact-social a:hover,
  .lp-rec-more a:hover {
    color: var(--lp-ink);
  }

  .lp-nav-links a:hover::after,
  .lp-contact-social a:hover::after,
  .lp-rec-more a:hover::after {
    left: 0;
    right: 0;
  }

  .lp-hero {
    position: relative;
    padding: clamp(96px, 16vw, 200px) 0 clamp(80px, 12vw, 160px);
    text-align: center;
  }

  .lp-crest {
    display: flex;
    justify-content: center;
    margin-bottom: clamp(28px, 4vw, 48px);
    color: var(--lp-gold);
  }

  .lp-display {
    max-width: 16ch;
    margin: 0 auto;
    color: var(--lp-ink);
    font-family: var(--lp-display);
    font-size: clamp(40px, 6.4vw, 88px);
    font-weight: 400;
    line-height: 1.04;
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }

  .lp-display span,
  .lp-contact-title span {
    color: var(--lp-sapphire);
    font-family: var(--lp-serif);
    font-style: italic;
    font-weight: 400;
    letter-spacing: -0.005em;
    text-transform: none;
  }

  .lp-hero-line {
    max-width: 36ch;
    margin: clamp(28px, 4vw, 44px) auto 0;
    color: var(--lp-ink-2);
    font-family: var(--lp-serif);
