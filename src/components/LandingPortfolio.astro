      </div>
    </section>

    <section id="path" class="lp-section">
      <div class="lp-wrap">
        <div class="lp-section-head lp-reveal">
          <div class="lp-ornament" aria-hidden="true">
            <span class="lp-rule"></span>
            <span set:html={cross()} />
            <span class="lp-rule"></span>
          </div>
          <h2 class="lp-section-title">Where the journey has taken me</h2>
          <p class="lp-saying"><em>A journey of a thousand miles begins with a single step.</em></p>
          <p class="lp-sub">{site.about}</p>
        </div>

        <div class="lp-path lp-reveal">
          {path.map((item) => (
            <article class="lp-path-item">
              <div class="lp-path-year">{item.year}</div>
              <div>
                <h3 class="lp-path-title">{item.title}</h3>
                <p class="lp-path-inst">{item.inst}</p>
                <p class="lp-path-desc">{item.desc}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section id="recognition" class="lp-section">
      <div class="lp-wrap">
        <div class="lp-section-head lp-reveal">
          <div class="lp-ornament" aria-hidden="true">
            <span class="lp-rule"></span>
            <span set:html={cross()} />
            <span class="lp-rule"></span>
          </div>
          <h2 class="lp-section-title">Learnings</h2>
          <p class="lp-sub">Short courses and certifications taken along the way</p>
