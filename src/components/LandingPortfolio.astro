---
const site = {
  name: "Seth Mbasha",
  hero: {
    sentence:
      "I am working across AI engineering, data science, and machine learning — my work moves toward problems where technical rigor reaches communities current technology overlooks.",
    focus:
      "NLP for low-resource African languages · Edge AI and embedded systems for African infrastructure · Narrowing the digital divide through quiet, deliberate work.",
  },
  about:
    "Computer Science at Uganda Christian University. Equitech Futures Applied Data Institute Fellow. The work moves between NLP research on low-resource languages, data systems for social impact, embedded engineering, and leadership across technical and operational rooms. The practical question underneath it all is the same one, what does it take to deploy something useful where infrastructure is thin?",
  email: "sethmbasha@gmail.com",
  social: {
    github: "https://github.com/mbashas",
    linkedin: "https://www.linkedin.com/in/mbashaseth",
    x: "https://x.com/dearmbasha",
  },
};

const featured = [
  {
    id: "gandabert",
    title: "GandaBERT",
    sub: "A classifier for Luganda news, built from a corpus that did not exist.",
    category: "Natural Language Processing",
    year: "2025",
    cs: {
      challenge:
        "Luganda is spoken by millions across Uganda. It has almost no public NLP infrastructure — no labeled corpus large enough to train against, no off-the-shelf classifier to fall back on. The task was not only to fit a model, but to make one possible.",
      approach:
        "I assembled a 2,600-article corpus by combining native sources, careful machine translation of English news, and synthetic augmentation calibrated to the language's morphology. I fine-tuned Multilingual BERT, then served the model through a small FastAPI layer with a lightweight web demo so anyone could try it on a paragraph of their own.",
      outcome:
        "The classifier reaches 85.7% accuracy across five categories. The corpus, more than the model, is the part I expect to outlive this project.",
    },
    tech: ["Python", "PyTorch", "Hugging Face", "FastAPI"],
    links: {
      code: "https://github.com/mbashas/gandabert",
      demo: "https://gandabert-demo.vercel.app",
    },
  },
  {
    id: "waterboard",
    title: "WaterBoard Analytics",
    sub: "A shared dashboard for water utilities in four countries.",
    category: "Data Systems",
    year: "2025",
    cs: {
      challenge:
        "Operators in Uganda, Cameroon, Malawi, and Lesotho were comparing performance against the WHO/UNICEF service ladder by spreadsheet. Regulators could not run their own questions; engineers became a bottleneck for everyone else.",
      approach:
        "I designed a role-based dashboard separating regulator, operator, and admin views over one schema, and built service-ladder visualizations that drill down by country. A small assistant, backed by Gemini, translates plain-language questions into pandas queries against the live data, with previews and guard-rails before anything runs.",
      outcome:
        "Shipped during the Equitech Futures Fellowship as production tooling for partner utilities. People without engineering backgrounds can ask their own questions and get answers they can cite.",
    },
    tech: ["Python", "Streamlit", "Plotly", "Gemini API", "pandas"],
    links: { code: "https://github.com/mbashas/waterboard-analytics" },
  },
  {
    id: "malaria",
    title: "Malaria Detection",
    sub: "Looking for the shortcuts a model takes when no one is watching.",
    category: "Responsible AI",
    year: "2025",
    cs: {
      challenge:
        "Medical-imaging models can learn the wrong things — backgrounds, scanner artifacts, label leakage — and still post good numbers in the lab. The failures show up later, in places the original authors do not see.",
      approach:
        "I am probing shortcut learning in malaria-detection models trained on Ghana health data, comparing what the network actually attends to against the regions a clinician would. The work is ongoing.",
      outcome:
        "Early-stage, but oriented toward a deployment standard, not a benchmark score: a model that can be honestly used in a clinic in Accra, not only one that ranks well on a held-out set.",
    },
    tech: ["Python", "PyTorch"],
    links: { code: "https://github.com/mbashas/malaria-detection" },
  },
];

const otherWork = [
  {
    year: "2024",
    title: "Agora Hub",
    sub: "Collaborative task management — Django + React.",
    link: "https://github.com/mbashas/agora-hub",
  },
  {
    year: "2024",
    title: "Smart Traffic Light",
    sub: "Adaptive four-way intersection with eight ultrasonic sensors and an emergency-vehicle override.",
    link: "https://github.com/mbashas/smart-traffic-light",
  },
  {
    year: "2023",
    title: "Smart Home Security",
    sub: "Motion-detection alerting with a custom PCB layout.",
    link: "https://github.com/mbashas/smart-home-security",
  },
];

const path = [
  {
    year: "2025",
    title: "Equitech Futures Fellow",
    inst: "Applied Data Institute · 1 of 25 selected globally",
    desc: "A 10-week intensive in Bayesian statistics, deep learning, and causal inference — running alongside data work for water utilities in Uganda, Cameroon, Malawi, and Lesotho, and a parallel research in investigating spurious correlation thread on malaria detection models.",
  },
  {
    year: "2025",
    title: "Rhodes Forum · Deep Learning Indaba · Cohere Labs · Stanford",
    inst: "Where curiosity led",
    desc: "Conferences, workshops, and convenings — including Stanford's Precision Medicine & Data Science in Diabetes program. Time spent listening to where the field is heading, what others are wrestling with, and which questions deserve to come home with me.",
  },
  {
    year: "2024 — 2025",
    title: "Local Committee President",
    inst: "AIESEC Uganda",
    desc: "Led the chapter through 46% growth in active membership; managed budget and partnerships with Baraka Community Foundation and Happy Times Childcare Initiative.",
  },
  {
    year: "2024",
    title: "Embedded Systems Intern",
    inst: "Uganda Industrial Research Institute",
    desc: "Three months on hardware projects between research seasons — sensor integration, PCB design, and a working security-system prototype.",
  },
  {
    year: "2023 — 2024",
    title: "Global Consultant",
    inst: "AIESEC International · Information Management",
    desc: "Resolved global platform issues, translated user feedback into product fixes, and helped close the loop between members and engineering.",
  },
  {
    year: "2022 — 2026",
    title: "B.Sc. Computer Science",
    inst: "Uganda Christian University",
    desc: "AI, data structures, big-data analytics, robotics, embedded systems. Graduating July 2026.",
  },
];

const recognition = [
  { name: "AWS Certified Cloud Practitioner", issuer: "Amazon Web Services" },
  { name: "Exploratory Data Analysis for Machine Learning", issuer: "IBM" },
  { name: "Precision Medicine & Data Science in Diabetes", issuer: "Stanford Deep Data Research Center" },
  { name: "Foundations of Data Science", issuer: "Google" },
  { name: "Data Analytics", issuer: "ALX" },
  { name: "IT Essentials", issuer: "Cisco" },
];

const reading = [
  {
    title: "Where Good Ideas Come From",
    author: "Steven Johnson",
    quote: "Chance favors the connected mind.",
  },
  {
    title: "What Is Intelligence?",
    subtitle: "Lessons from AI about evolution, computing, and minds",
    author: "Blaise Agüera y Arcas",
  },
];

const contact = {
  pull: "“The best way to predict the future is to invent it. The second best is to talk with someone who is.”",
  pullAttr: "— a working belief",
  currently:
    "Sharpening technical depth, mapping the research landscape, and learning to recognise the problems I am ready to take on.",
};

const cross = (size = 22) => `
  <svg width="${size}" height="${size}" viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round" aria-hidden="true">
    <path d="M16 3 L18 7 L22 7 L22 11 L26 13 L28 16 L26 19 L22 21 L22 25 L18 25 L16 29 L14 25 L10 25 L10 21 L6 19 L4 16 L6 13 L10 11 L10 7 L14 7 Z"></path>
    <circle cx="16" cy="16" r="1.6" fill="currentColor" stroke="none"></circle>
  </svg>`;

const arrow = (size = 14) => `
  <svg width="${size}" height="${size}" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M3 8 H13 M9 4 L13 8 L9 12"></path>
  </svg>`;

const emailDisplay = site.email.replace("@", "[at]");
---

<div class="lp-page">
  <nav class="lp-nav" aria-label="Primary navigation">
    <div class="lp-wrap lp-nav-inner">
      <a class="lp-brand" href="#top">
        <span set:html={cross(20)} />
        <span>Mbasha Seth</span>
      </a>
      <div class="lp-nav-links">
        <a href="#work">Work</a>
        <a href="#path">Path</a>
        <a href="#contact">Contact</a>
      </div>
    </div>
  </nav>

  <main>
    <header class="lp-hero" id="top">
      <div class="lp-wrap">
        <div class="lp-crest lp-reveal" set:html={cross(44)} />
        <h1 class="lp-display lp-reveal">
          Mbasha <span>Seth</span>
        </h1>
        <p class="lp-hero-line lp-reveal">{site.hero.sentence}</p>
        <p class="lp-hero-focus lp-reveal">{site.hero.focus}</p>
      </div>
    </header>

    <section id="work" class="lp-section">
      <div class="lp-wrap">
        <div class="lp-section-head lp-reveal">
          <div class="lp-ornament" aria-hidden="true">
            <span class="lp-rule"></span>
            <span set:html={cross()} />
            <span class="lp-rule"></span>
          </div>
          <h2 class="lp-section-title">Selected Work</h2>
          <p class="lp-saying"><em>Gakyali Mabaga.</em></p>
          <p class="lp-sub">
            A Luganda saying — <em>so little done, so much more to do.</em> Three projects already shipped, with the rest of the road still ahead.
          </p>
        </div>

        <div class="lp-work-list lp-reveal">
          {featured.map((project) => (
            <details class="lp-work-details">
              <summary class="lp-work-item">
                <span class="lp-work-year">{project.year}</span>
                <span class="lp-work-body">
                  <span class="lp-work-title">{project.title}</span>
                  <span class="lp-work-sub">{project.sub}</span>
                  <span class="lp-work-category">{project.category}</span>
                </span>
                <span class="lp-work-arrow" set:html={arrow(16)} />
              </summary>

              <div class="lp-case-study">
                <div class="lp-case-inner">
                  <div class="lp-ornament lp-ornament-left" aria-hidden="true">
                    <span class="lp-rule"></span>
                    <span set:html={cross(18)} />
                    <span class="lp-rule"></span>
                  </div>
                  <div class="lp-case-block">
                    <h3>The challenge</h3>
                    <p>{project.cs.challenge}</p>
                  </div>
                  <div class="lp-case-block">
                    <h3>The approach</h3>
                    <p>{project.cs.approach}</p>
                  </div>
                  <div class="lp-case-block">
                    <h3>Where it stands</h3>
                    <p>{project.cs.outcome}</p>
                  </div>
                  <div class="lp-case-block">
                    <h3>Built with</h3>
                    <p class="lp-tech">{project.tech.join(" · ")}</p>
                  </div>
                  <div class="lp-case-links">
                    {project.links.demo && (
                      <a href={project.links.demo} target="_blank" rel="noopener noreferrer" class="lp-primary-link">
                        View demo <span set:html={arrow(12)} />
                      </a>
                    )}
                    {project.links.code && (
                      <a href={project.links.code} target="_blank" rel="noopener noreferrer">
                        Source <span set:html={arrow(12)} />
                      </a>
                    )}
                  </div>
                </div>
              </div>
            </details>
          ))}
        </div>

        <details class="lp-other-work lp-reveal">
          <summary>
            <span class="lp-label-closed">Other work</span>
            <span class="lp-label-open">Hide other work</span>
          </summary>
          <div class="lp-other-list">
            {otherWork.map((item) => (
              <a class="lp-other-item" href={item.link} target="_blank" rel="noopener noreferrer">
                <span class="lp-other-year">{item.year}</span>
                <span>
                  <span class="lp-other-title">{item.title}</span>
                  <span class="lp-other-sub">{item.sub}</span>
                </span>
                <span class="lp-other-link">View →</span>
