---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Page not found | Mbasha Seth" description="This page does not exist.">
  <main
    style="min-height: 100vh; display: grid; place-items: center; padding: 48px; background: #faf8f3;"
  >
    <div style="max-width: 720px;">
      <h1 style="margin: 0 0 12px; font-family: Inter, system-ui, -apple-system, Segoe UI, Roboto, sans-serif;">
        Page not found
      </h1>
      <p
        style="margin: 0 0 20px; font-family: Inter, system-ui, -apple-system, Segoe UI, Roboto, sans-serif; line-height: 1.6;"
      >
        The page you’re looking for doesn’t exist.
      </p>
      <a href="/" style="font-family: Inter, system-ui, -apple-system, Segoe UI, Roboto, sans-serif;">
        Go back home
      </a>
    </div>
  </main>
</BaseLayout>
